[include mainsail.cfg]
[include MMU.cfg]
#[include autotune_tmc.cfg]

[mcu]
serial: /dev/serial/by-id/usb-Klipper_stm32g0b1xx_22002C001750344D30363620-if00

[virtual_sdcard]
path: /home/trident/printer_data/gcodes
on_error_gcode: CANCEL_PRINT

[printer]
kinematics: none
max_velocity: 1000
max_accel: 1000


